    "phase2_test": 4000
  },
  "phase_labels": {
    "phase1": [
      "BENIGN",
      "DDOS-ICMP_FLOOD",
      "DDOS-UDP_FLOOD",
      "DDOS-TCP_FLOOD",
      "DDOS-SYN_FLOOD",
      "DOS-UDP_FLOOD",
      "DOS-TCP_FLOOD",
      "DOS-SYN_FLOOD"
    ],
    "phase2": [
      "BENIGN",
      "MIRAI-GREETH_FLOOD",
      "MIRAI-GREIP_FLOOD",
