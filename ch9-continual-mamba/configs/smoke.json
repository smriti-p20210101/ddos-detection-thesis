{
  "dataset_root": "D:/4-2/CIC_IOT_Dataset2023",
  "merged_csv_subdir": "MERGED_CSV",
  "output_dir": "outputs",
  "seed": 42,
  "device": "cuda",
  "file_split": {
    "train_ratio": 0.8,
    "val_ratio": 0.1
