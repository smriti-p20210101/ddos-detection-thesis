{
  "dataset_root": "D:/4-2/TON_IoT_Network",
  "merged_csv_subdir": "MERGED_CSV",
  "output_dir": "outputs/toniot_4task_mamba_kan_cfa_ewc",
  "seed": 42,
  "device": "cuda",
  "file_split": {
    "train_ratio": 0.7,
    "val_ratio": 0.1
  },
  "max_samples_per_split": {
    "train": 70000,
    "val": 15000,
    "test": 20000
  },
  "tasks": [
    {
      "name": "task1_volumetric",
      "labels": [
        "normal",
        "ddos",
        "dos"
      ]
    },
    {
      "name": "task2_scan_web",
      "labels": [
        "normal",
        "scanning",
        "injection",
        "xss"
      ]
    },
    {
      "name": "task3_access",
      "labels": [
        "normal",
        "password",
        "backdoor"
      ]
    },
    {
      "name": "task4_rare_malware",
      "labels": [
        "normal",
        "ransomware",
        "mitm"
      ]
    }
  ],
  "training": {
    "batch_size": 256,
    "num_workers": 0,
    "epochs_per_task": 12,
    "joint_epochs": 24,
    "lr": 0.0008,
    "weight_decay": 0.0001,
    "label_smoothing": 0.05,
    "grad_clip_norm": 1.0,
    "scheduler": "cosine",
    "warmup_epochs": 2
  },
  "model": {
    "d_model": 96,
    "seq_len": 10,
    "ssm_layers": 2,
    "dropout": 0.1,
    "kan_grid": 8,
    "kan_hidden": 96,
    "variant": "mamba_kan"
  },
  "ewc": {
    "lambda": 1.0,
    "fisher_batches": 120,
    "fisher_weighting": "class_frequency"
  },
  "continual": {
    "method": "ewc",
    "buffer_size": 0
  }
}
