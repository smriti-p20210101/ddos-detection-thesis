  "model": {
    "d_model": 48,
    "seq_len": 10,
    "ssm_layers": 1,
    "dropout": 0.1,
    "kan_grid": 4,
    "kan_hidden": 48,
    "variant": "mamba_kan"
  },
  "ewc": {
    "lambda": 1.0,
    "fisher_batches": 3
  },
  "continual": {
    "method": "er",
    "buffer_size": 1000,
    "replay_batch_size": 64,
    "replay_alpha": 1.0
  }
}
